<!DOCTYPE html>
<html>
    <head>
        <metal:head use-macro="request.macros['head']" />
        <title>Serial ${serial}/${last_changelog_serial}</title>
        <style>
            body {
                margin: 1em;
            }
            ul.nav {
                list-style: none;
                padding: 0;
                margin: 0;
            }
            ul.nav li {
                display: inline-block;
                padding: 0;
                margin: 0.5em;
            }
            table {
                width: 100%;
                border-collapse: collapse;
            }
            table tr:nth-child(even) {
                background: #f4f4f4;
            }
            table td {
                vertical-align: top;
                padding: 0.5em;
            }
            table div.serial {
                display: flex;
                justify-content: space-between;
                & > span {
                    padding-right: 2em;
                }
            }
            table td pre {
                margin: 0;
            }
            table td pre span.remove {
                background: #ffdddd;
            }
            table td pre span.insert {
                background: #ddffdd;
            }
            :target {
                background-color: #ffa;
            }
        </style>
    </head>
    <body>
        <h1>Serial ${serial}/${last_changelog_serial}</h1>
        <ul class="nav">
            <li><a href="${request.route_url('keyfs', _query=dict(query=query))}">Back to search</a></li>
            <li><a tal:omit-tag="serial - 1 < 0" href="${request.route_url('keyfs_changelog', serial=serial - 1,_query=dict(query=query))}">Previous serial</a></li>
            <li><a tal:omit-tag="serial +1 > last_changelog_serial" href="${request.route_url('keyfs_changelog', serial=serial + 1,_query=dict(query=query))}">Next serial</a></li>
            <li><a tal:omit-tag="serial == last_changelog_serial" href="${request.route_url('keyfs_changelog', serial=last_changelog_serial,_query=dict(query=query))}">Latest serial</a></li>
        </ul>
        <h3>Parent keys</h3>
        <ul>
            <li tal:repeat="parent_key parent_keys">${parent_key.name} <a name="${parent_key.fragment}">${parent_key.relpath}</a> at serial <a href="${request.route_url('keyfs_changelog', serial=parent_key.serial,_query=dict(query=query),_anchor=parent_key.fragment)}">${parent_key.serial}</a></li>
        </ul>
        <h3>Changes</h3>
        <ul>
            <li tal:repeat="change changes">${change.name} <a href="#${change.fragment}">${change.relpath}</a></li>
        </ul>
        <table>
            <thead>
                <tr>
                    <th>Key</th>
                    <th>Data</th>
                </tr>
            </thead>
            <tbody>
                <tr tal:repeat="change changes">
                    <td>
                        <div><a name="${change.fragment}"><strong>${change.name}</strong>&nbsp;<code>&lt;${change.type}&gt;</code> <strong>${change.relpath}</strong></a></div>
                        <div class="serial">Previous serial<span><a href="${request.route_url('keyfs_changelog', serial=change.previous_serial, _query=dict(query=query)) + '#' + change.fragment}" tal:omit-tag="change.previous_serial < 0 or change.previous_serial == serial">${change.previous_serial}</a></span></div>
                        <div class="serial">Latest serial<span><a href="${request.route_url('keyfs_changelog', serial=change.latest_serial, _query=dict(query=query)) + '#' + change.fragment}" tal:omit-tag="change.latest_serial < 0 or change.latest_serial == serial">${change.latest_serial}</a></span></div>
                        <div tal:condition="change.parent_key">Parent key ${change.parent_key.name} <a href="#${change.parent_key.fragment}">${change.parent_key.relpath}</a></div>
                    </td>
                    <td>
                        <pre>
<span tal:repeat="diff change['diffed']" tal:attributes="class diff[0]">${diff[1]}</span>
                        </pre>
                    </td>
                </tr>
            </tbody>
        </table>
    </body>
</html>
