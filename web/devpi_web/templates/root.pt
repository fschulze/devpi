<!doctype html>
<html>
    <head>
        <title>devpi</title>
        <metal:head use-macro="request.macros['head']" />
    </head>
    <body>
        <metal:search use-macro="request.macros['navigation']" />
        <div id="content">
            <metal:macros tal:repeat="name request.registry['macros'].get_group('root')" use-macro="macros[name]" />
        </div>
        <metal:footer use-macro="request.macros['footer']" />
    </body>
</html>
