<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="content-type" content="text/html; charset=utf-8">
        <meta name="viewport" content="initial-scale=1.0">
        <title><metal:title define-slot="title">devpi</metal:title></title>
        <metal:macros tal:repeat="name request.registry['macros'].get_group('html_head')" use-macro="macros[name]" />
    </head>
    <body>
        <header>
            <div class="headertop">
                <metal:macros tal:repeat="name request.registry['macros'].get_group('main_header_top')" use-macro="macros[name]" />
            </div>
            <nav>
                <metal:macros tal:repeat="name request.registry['macros'].get_group('main_navigation')" use-macro="macros[name]" />
            </nav>
            <metal:macros tal:repeat="name request.registry['macros'].get_group('main_header')" use-macro="macros[name]" />
            <metal:endofheader define-slot="endofheader"></metal:endofheader>
        </header>
        <metal:contentwrapper define-slot="content-wrapper">
            <main tal:attributes="class main_class | None">
                <metal:content define-slot="content"></metal:content>
            </main>
        </metal:contentwrapper>
        <footer>
            <metal:footerstart define-slot="footerstart" />
            <metal:macros tal:repeat="name request.registry['macros'].get_group('main_footer')" use-macro="macros[name]" />
            <metal:footerend define-slot="footerend" />
        </footer>
    </body>
</html>
