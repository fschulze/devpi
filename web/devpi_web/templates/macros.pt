<metal:head define-macro="head">
    <metal:macros use-macro="macros.render_group('html_head')" />
</metal:head>
<metal:search define-macro="navigation">
    <div class="header">
        <metal:headersearch use-macro="macros.header_search" />
        <div id="navigation">
            <metal:macros use-macro="macros.render_group('main_navigation')" />
        </div>
        <metal:headerstatus use-macro="macros.header_status" />
        <metal:endofheader define-slot="endofheader" />
    </div>
</metal:search>
<metal:footer define-macro="footer">
    <footer>
        <metal:footer define-slot="footer" />
        <metal:macros use-macro="macros.render_group('main_footer')" />
    </footer>
</metal:footer>
